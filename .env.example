# ── Telegram ──

# Bot token from BotFather.
#
# CRITICAL SECURITY: this token grants full code execution on your host
# via the CLIs running with --allow-all-tools / bypassPermissions.
# Treat it like an SSH private key:
#   - never commit (.gitignore covers .env)
#   - never paste in screenshots/logs
#   - revoke via @BotFather immediately if leaked
# See SECURITY.md "Threat model" for the full reasoning.
TELEGRAM_BOT_TOKEN=

# Allowed Telegram user ID.
# If left blank, the bridge starts in bootstrap mode and replies with your user ID.
TELEGRAM_ALLOWED_USER_ID=

# ── Kilo (HTTP backend) ──

# Port for the bridge-managed kilo serve process (default: 4097).
# The bridge spawns kilo serve on startup and shuts it down on exit.
# Change this if port 4097 is already in use on your machine.
# KILO_SERVE_PORT=4097

# Shell used to spawn kilo serve (default: $SHELL, then /bin/sh).
# Override if kilo requires a specific login shell (e.g. /bin/zsh) to resolve
# PATH, keychain hooks, or other shell initialisation from ~/.zshrc.
# KILO_SERVE_SHELL=/bin/zsh

# Legacy escape hatch: if set, the bridge SKIPS spawning kilo serve and
# connects directly to this URL instead. Use only if you manage kilo serve
# externally (advanced setups, debugging).
# KILO_SERVE_URL=http://127.0.0.1:4097
#
# SECURITY NOTE: if pointing to a remote host (non-localhost), ensure the
# endpoint is protected — e.g. behind a VPN, WireGuard, or SSH tunnel.
# The bridge adds no TLS or additional auth beyond KILO_SERVER_PASSWORD.
# An exposed Kilo server grants arbitrary tool execution to anyone who can
# reach it, independent of Telegram authentication.

# Optional Basic Auth for kilo serve (only used in legacy KILO_SERVE_URL mode;
# bridge-spawned kilo always runs without a password).
KILO_SERVER_USERNAME=kilo
KILO_SERVER_PASSWORD=

# Path to Kilo config for agent discovery.
# Supports opencode.json (legacy) and kilo.jsonc (current).
KILO_CONFIG_PATH=~/.config/kilo/opencode.json

# Thinking variant sent to Kilo (default "high"). Values: low, high, xhigh
# KILO_VARIANT=high

# ── Agent defaults ──

# Preferred primary agent for new Kilo sessions (default: codex)
# BRIDGE_DEFAULT_AGENT=codex

# Suggested alternatives when the current agent is rate-limited (default: sonnet)
# BRIDGE_AGENT_FALLBACKS=sonnet

# ── Workspace ──

# Default workspace for /new when no path is provided (default: current directory)
# BRIDGE_DEFAULT_DIRECTORY=.

# Path to the bridge SQLite database (default: ./sessions.db in the current directory)
# BRIDGE_DB_PATH=./sessions.db

# ── CLI binary paths ──
# Override if CLIs are not on PATH (e.g., launchd / non-interactive environments).
# Use absolute paths for reliable service startup.

# BIN_CODEX=codex
# BIN_COPILOT=copilot
# BIN_GEMINI=gemini
# BIN_CLAUDE=claude

# ── Session scanner paths ──
# Where the bridge looks for existing CLI sessions.
# Override if CLIs store data in non-standard locations.

# SCAN_PATH_CLAUDE=~/.claude/projects
# SCAN_PATH_CODEX=~/.codex/sessions
# SCAN_PATH_COPILOT=~/.copilot
# SCAN_PATH_QWEN=~/.qwen/tmp
# SCAN_PATH_GEMINI=~/.gemini/tmp
# SCAN_PATH_KILO=~/.local/share/kilo/kilo.db

# ── Model discovery paths ──
# Override if CLIs store model data in non-standard locations.

# CODEX_MODELS_CACHE_PATH=~/.codex/models_cache.json
# CLAUDE_CONFIG_PATH=~/.claude.json

# ── Gemini options ──
# Required for Gemini Code Assist plans (OAuth + GCP project).
# Without this, Gemini CLI falls back to free personal quota.
# This variable is passed through to the Gemini subprocess environment — it is
# not consumed by the bridge itself.
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ── Copilot options ──

# Allow Copilot CLI to auto-approve all tool calls (default true).
# Set to false to require manual approval (Copilot will prompt and may hang).
# COPILOT_ALLOW_ALL_TOOLS=true

# ── Timeouts & limits ──

# Per-backend exec timeout in milliseconds (default 300000 = 5 minutes each)
# CODEX_TIMEOUT_MS=300000
# COPILOT_TIMEOUT_MS=300000
# GEMINI_TIMEOUT_MS=300000
# CLAUDE_TIMEOUT_MS=300000

# Claude permission mode (default: true = yolo, all tools auto-approved).
# Set to false to enable interactive permission prompts via Telegram inline keyboard.
# Requires the Claude Code CLI to support --permission-prompt-tool stdio.
# BRIDGE_CLAUDE_DANGEROUS_SKIP_PERMISSIONS=true

# Request timeout in milliseconds (default 120000 = 2 minutes)
# KILO_TIMEOUT_MS=120000

# Retry attempts on transient Kilo errors (default 2)
# KILO_RETRIES=2

# Preflight session status timeout in milliseconds (default 5000)
# KILO_STATUS_TIMEOUT_MS=5000

# Session abort timeout in milliseconds (default 10000)
# KILO_ABORT_TIMEOUT_MS=10000

# ── Kilo async turn management ──

# Timeout for the prompt_async submission request (default 15000 = 15s)
# KILO_SUBMIT_TIMEOUT_MS=15000

# Maximum wall-clock time to wait for a Kilo turn to complete (default 1800000 = 30 min)
# KILO_TURN_TIMEOUT_MS=1800000

# Max time without a successful status poll before assuming the server is unreachable (default 120000 = 2 min)
# KILO_STALE_TIMEOUT_MS=120000

# How often to poll session status during a turn (default 3000 = 3s)
# KILO_POLL_INTERVAL_MS=3000

# Delay before the first poll after submission, so Kilo registers the turn as busy (default 5000 = 5s)
# KILO_POLL_INITIAL_DELAY_MS=5000

# /cleanup only deletes bridge-created Kilo sessions whose user-turn count
# is at or below this threshold. The count is exact (one row per real user
# prompt, derived from the Kilo message table), not an estimation. Bridge
# ownership itself is determined by a deterministic source='bridge' flag set
# at session creation time, not by a title pattern. Default 5.
# KILO_CLEANUP_MAX_ROUNDS=5

# Rate limiting: max requests per window (applies globally to commands, text messages,
# and callback queries). Default: 20 per 60s.
# RATE_LIMIT_MAX=20
# RATE_LIMIT_WINDOW_MS=60000

# Debounce window in milliseconds for coalescing consecutive Telegram message
# fragments into one LLM turn. Telegram splits messages longer than 4096
# characters into multiple consecutive sends. The bridge buffers fragments and
# waits this long after the last fragment before forwarding the combined text
# to the backend. Set to 0 to disable coalescing. Default: 1500
# BRIDGE_MESSAGE_DEBOUNCE_MS=1500

# TTL for pending Kilo permission prompts before auto-expiry (ms, default 300000 = 5 min)
# BRIDGE_PENDING_PERMISSION_TTL_MS=300000

# TTL for pending "Custom path..." prompts before auto-expiry (ms, default 300000 = 5 min)
# BRIDGE_PENDING_PATH_TTL_MS=300000

# Delay between the /restart reply and the SIGINT that triggers graceful
# shutdown (ms, default 500). Gives Telegram time to flush the reply before
# the bot stops. Increase on slow networks or supervisors that need more
# shutdown headroom.
# BRIDGE_RESTART_DELAY_MS=500

# ── Logging ──

# Structured log level: debug, info, warn, error
# LOG_LEVEL=info

# NDJSON log file path
# LOG_FILE_PATH=./logs/bridge.ndjson

# SQLite event store path for durable high-value logs
# LOG_DB_PATH=./logs/bridge-events.db

# Delete persisted log events older than N days
# LOG_RETENTION_DAYS=14

# Max bytes before log file is rotated (default 10485760 = 10 MB)
# LOG_MAX_FILE_SIZE=10485760

# Number of rotated log files to keep (default 5)
# LOG_MAX_FILES=5

# ── LM Studio (privacy-first — native v1 API, stateful) ──
#
# The bridge uses LM Studio's native /api/v1/chat endpoint. Conversation
# history is managed entirely by LM Studio — the bridge stores only an
# opaque response_id per session for thread continuity. No conversation
# content is persisted by the bridge.

# Base URL for the LM Studio local server (default: http://127.0.0.1:1234).
# When pointing to localhost (the default), no data leaves your machine.
# LMSTUDIO_BASE_URL=http://127.0.0.1:1234

# Model identifier to use (e.g. qwen3-0.6b, ibm/granite-4-micro).
# If left blank, the bridge auto-detects the first LLM model available
# in LM Studio. Set this explicitly for predictability.
# LMSTUDIO_MODEL=

# Optional API token for authenticated LM Studio servers.
# Generate one from the Developer page in LM Studio. Leave blank if
# authentication is not enabled (the default).
# LMSTUDIO_API_TOKEN=

# Request timeout in milliseconds (default 120000 = 2 min).
# Local models can be slow on CPU — increase if you run large models.
# LMSTUDIO_TIMEOUT_MS=120000

# Maximum output tokens per response (default 2048).
# LMSTUDIO_MAX_TOKENS=2048

# Timeout for the /api/v1/models auto-detect probe (default 3000 ms).
# LMSTUDIO_DETECT_TIMEOUT_MS=3000

# ── Debug ──

# Set to 1 for startup-only smoke checks
# BRIDGE_DRY_RUN=1
